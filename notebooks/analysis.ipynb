# 📊 Seismic Signal Analysis with Python

This notebook simulates and visualizes seismic signal data using common scientific libraries in Python.

import numpy as np
import matplotlib.pyplot as plt
from scipy import signal

# Simulate a seismic signal
fs = 100  # Sampling frequency
t = np.linspace(0, 5, fs*5)
x = np.sin(2*np.pi*10*t) + 0.5*np.random.randn(len(t))

# Plot the raw signal
plt.figure(figsize=(12, 4))
plt.plot(t, x)
plt.title("Simulated Seismic Signal")
plt.xlabel("Time (s)")
plt.ylabel("Amplitude")
plt.grid(True)
plt.show()

f, t_spec, Sxx = signal.spectrogram(x, fs)
plt.figure(figsize=(10, 4))
plt.pcolormesh(t_spec, f, 10 * np.log10(Sxx), shading='gouraud')
plt.ylabel('Frequency [Hz]')
plt.xlabel('Time [sec]')
plt.title('Spectrogram')
plt.colorbar(label='Power/Frequency (dB/Hz)')
plt.tight_layout()
plt.show()
