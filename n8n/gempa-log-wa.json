        "functionCode": "const g = $json.Infogempa;\nreturn [{\n  json: {\n    Tanggal: g.Tanggal,\n    Jam: g.Jam,\n    Wilayah: g.Wilayah,\n    Magnitude: g.Magnitude,\n    Kedalaman: g.Kedalaman,\n    Potensi: g.Potensi\n  }\n}];"
      },
