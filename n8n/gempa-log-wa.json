      "name": "Ambil Info Gempa",
      "type": "n8n-nodes-base.httpRequest",
      "position": [300, 200]
    },
    {
      "parameters": {
        "functionCode": "const g = $json.Infogempa;\nreturn [{\n  json: {\n    pesan: `📢 *Info Gempa Terbaru*\n📅 ${g.Tanggal} ${g.Jam}\n📍 ${g.Wilayah}\n💥 Magnitudo: ${g.Magnitude}\n📏 Kedalaman: ${g.Kedalaman}\n🌊 ${g.Potensi}`\n  }\n}];"
      },
      "id": "Format_Pesan",
      "name": "Format WhatsApp",
      "type": "n8n-nodes-base.function",
      "position": [500, 100]
    },
    {
      "parameters": {
        "url": "http://localhost:3000/send",
        "method": "POST",
        "bodyParametersJson": "={\n  \"number\": \"6285260245100\",\n  \"message\": \"{{$json.pesan}}\"\n}"
      },
      "id": "Kirim_WA",
      "name": "Kirim ke WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "position": [700, 100]
    },
    {
